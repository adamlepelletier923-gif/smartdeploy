{
  "title": "SmartDeploy Release Health",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(smartdeploy_http_requests_total[1m])) by (status)",
          "legendFormat": "status {{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 Latency",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(smartdeploy_http_request_duration_seconds_bucket[2m])) by (le, endpoint))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    }
  ]
}
